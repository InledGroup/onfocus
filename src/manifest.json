{
  "manifest_version": 3,
  "name": "OnFocus",
  "version": "1.0.0",
  "description": "Una extensión para propiciar la concentración.",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "idle",
    "notifications",
    "declarativeNetRequest"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "src/ui/popup/index.html"
  },
  "options_page": "src/ui/options/index.html",
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/ui/content-scripts/index.ts"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/onfocus-logo.png",
    "48": "icons/onfocus-logo.png",
    "128": "icons/onfocus-logo.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/ui/wizard/index.html",
        "src/ui/common/blocked.html"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}